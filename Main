import random
import tkinter as tk
from tkinter import messagebox, font
from abc import ABC, abstractmethod

# =========================
# === GAME STATE & DATA ===
# =========================

game_state = {
    "day": 1,
    "food": 20,
    "medicine": 5,
    "ammo": 10,
    "scrap": 10,
    "shelter_health": 100,
    "max_shelter_health": 100,
    "grid_size": 5,
    "max_grid_size": 10,
    "shelter_grid": [],
    "grid_health": [],
    "survivors": [
        {"name": "John", "health": 100, "max_health": 100, "role": "Combatant", "hunger": 0},
        {"name": "Jamie", "health": 100, "max_health": 100, "role": "Healer", "hunger": 0},
        {"name": "Taylor", "health": 100, "max_health": 100, "role": "Builder", "hunger": 0},
    ],
    "current_survivor": None,
    "in_hunt": False,
    "current_monster": None,
    "blocking": False,
    "design_mode": False,
    "repair_mode": False,
    "in_scavenge": False,
    "current_scavenge_location": None,
}

def init_grid(size):
    game_state["shelter_grid"] = [[0 for _ in range(size)] for _ in range(size)]
    game_state["grid_health"] = [[2 for _ in range(size)] for _ in range(size)]

init_grid(game_state["grid_size"])

def max_survivors():
    # survivor cap scales with shelter size
    return game_state["grid_size"] * 2

# =====================
# === ROLE SYSTEM   ===
# =====================

class Role(ABC):
    @abstractmethod
    def perform_attack(self):
        pass

    def perform_heal(self, state):
        return 0

    def perform_build(self, state):
        return 0

    def scavenge_bonus(self, state):
        return {}

class Combatant(Role):
    def perform_attack(self):
        return random.randint(6, 12)

class Healer(Role):
    def perform_attack(self):
        return random.randint(3, 7)

    def perform_heal(self, state):
        if state["medicine"] > 0:
            heal_amount = random.randint(12, 22)
            state["medicine"] -= 1
            return heal_amount
        return 0

class Builder(Role):
    def perform_attack(self):
        return random.randint(2, 5)

    def perform_build(self, state):
        scrap_gain = random.randint(2, 4)
        state["scrap"] += scrap_gain
        return scrap_gain

class Scout(Role):
    # Better scavenge outcomes, slightly weaker attack
    def perform_attack(self):
        return random.randint(4, 8)

    def scavenge_bonus(self, state):
        # Increase chance of good finds, reduce ambush chance
        return {
            "good_find_bonus": 10,
            "ambush_penalty": -5,
        }

class Guardian(Role):
    # Stronger block / tank
    def perform_attack(self):
        return random.randint(4, 9)

# ========================
# === DISASTER SYSTEM  ===
# ========================

class Disaster(ABC):
    @abstractmethod
    def apply(self, state):
        pass

class ZombieRaid(Disaster):
    def apply(self, state):
        num_zombies = random.randint(2, 4)
        survivors = state["survivors"]
        for _ in range(num_zombies):
            if survivors:
                survivor = random.choice(survivors)
                damage = random.randint(5, 15)
                survivor["health"] -= damage
                slow_print(f"{survivor['name']} takes {damage} damage from zombies!")
                if survivor["health"] <= 0:
                    survivors.remove(survivor)
                    slow_print(f"{survivor['name']} has died.")
            else:
                break

        if state["grid_size"] > 0:
            hits = random.randint(1, 3)
            for _ in range(hits):
                x = random.randint(0, state["grid_size"] - 1)
                y = random.randint(0, state["grid_size"] - 1)
                if state["grid_health"][x][y] > 0:
                    state["grid_health"][x][y] -= 1
                    slow_print(f"Zombies damage the shelter at ({x},{y})!")
            state["shelter_health"] = max(0, state["shelter_health"] - random.randint(5, 15))
            slow_print("Zombies breach weak points! Shelter takes damage!")

class Storm(Disaster):
    def apply(self, state):
        damage = random.randint(10, 20)
        state["food"] = max(0, state["food"] - damage)
        state["medicine"] = max(0, state["medicine"] - damage // 2)
        roof_damage = random.randint(5, 15)
        state["shelter_health"] = max(0, state["shelter_health"] - roof_damage)
        slow_print(f"A storm destroys {damage} food and {damage // 2} medicine! Roof takes {roof_damage} damage!")

        if state["grid_size"] > 0:
            hits = random.randint(1, 3)
            for _ in range(hits):
                x = random.randint(0, state["grid_size"] - 1)
                y = random.randint(0, state["grid_size"] - 1)
                if state["grid_health"][x][y] > 0:
                    state["grid_health"][x][y] -= 1
                    slow_print(f"Storm batters the shelter at ({x},{y})!")

class SupplyDrop(Disaster):
    def apply(self, state):
        food_gain = random.randint(5, 10)
        med_gain = random.randint(2, 5)
        scrap_gain = random.randint(2, 6)
        state["food"] += food_gain
        state["medicine"] += med_gain
        state["scrap"] += scrap_gain
        slow_print(f"A supply drop arrives! +{food_gain} food, +{med_gain} medicine, +{scrap_gain} scrap.")

class RadiationLeak(Disaster):
    def apply(self, state):
        for survivor in state["survivors"][:]:
            damage = random.randint(5, 10)
            survivor["health"] -= damage
            slow_print(f"Radiation leak! {survivor['name']} takes {damage} damage.")
            if survivor["health"] <= 0:
                state["survivors"].remove(survivor)
                slow_print(f"{survivor['name']} has died.")
        damage = random.randint(10, 20)
        state["shelter_health"] = max(0, state["shelter_health"] - damage)
        slow_print(f"Radiation corrodes the shelter! Takes {damage} damage!")

class Famine(Disaster):
    def apply(self, state):
        loss = random.randint(5, 15)
        state["food"] = max(0, state["food"] - loss)
        slow_print(f"A creeping famine spoils {loss} food. Hunger grows.")

class BanditRaid(Disaster):
    def apply(self, state):
        stolen_food = min(state["food"], random.randint(3, 10))
        stolen_med = min(state["medicine"], random.randint(1, 3))
        state["food"] -= stolen_food
        state["medicine"] -= stolen_med
        slow_print(f"Bandits raid the outskirts! They steal {stolen_food} food and {stolen_med} medicine.")

# ====================
# === TEXT OUTPUT  ===
# ====================

def slow_print(text, speed=0.01):
    text_area.insert(tk.END, "\n")
    for char in text:
        text_area.insert(tk.END, char)
        text_area.see(tk.END)
        root.update()
        root.after(int(speed * 50), lambda: None)
    text_area.insert(tk.END, "\n")

# =========================
# === SHELTER MANAGEMENT ===
# =========================

def assign_role(survivor, role_instance):
    if survivor is None:
        messagebox.showwarning("Warning", "Select a survivor first!")
        return
    survivor["role"] = role_instance.__class__.__name__
    survivor["role_instance"] = role_instance
    slow_print(f"{survivor['name']} is now a {role_instance.__class__.__name__}.")
    update_shelter_ui()

def end_day():
    if game_state["in_hunt"] or game_state["in_scavenge"]:
        messagebox.showwarning("Warning", "Finish current mission first!")
        return

    for survivor in game_state["survivors"][:]:
        survivor["hunger"] += random.randint(1, 3)
        if survivor["hunger"] >= 10:
            survivor["health"] -= 5
            slow_print(f"{survivor['name']} is starving! Health reduced.")
        if survivor["health"] <= 0:
            game_state["survivors"].remove(survivor)
            slow_print(f"{survivor['name']} has died.")

    game_state["food"] -= len(game_state["survivors"])
    if game_state["food"] < 0:
        game_state["food"] = 0

    disasters = [ZombieRaid(), Storm(), SupplyDrop(), RadiationLeak(), Famine(), BanditRaid()]
    disaster = random.choice(disasters)
    disaster_name = disaster.__class__.__name__

    descriptions = {
        "ZombieRaid": [
            "A violent zombie raid shakes the shelter!",
            "A fierce group of zombies attacks!",
            "Chaotic screams echo as zombies breach the walls!",
        ],
        "Storm": [
            "A devastating storm destroys supplies!",
            "Heavy rain and wind wreak havoc!",
            "A wild storm batters the shelter!",
        ],
        "SupplyDrop": [
            "An unexpected supply drop arrives!",
            "A mysterious package falls from the sky!",
            "Lucky find! Supplies delivered!",
        ],
        "RadiationLeak": [
            "A toxic radiation leak poisons the air!",
            "Deadly radiation spreads through the shelter!",
            "A hazardous leak threatens everyone!",
        ],
        "Famine": [
            "A slow famine creeps in, spoiling food.",
            "Rot spreads through your stores.",
        ],
        "BanditRaid": [
            "Bandits strike under cover of darkness.",
            "Gunshots echo as bandits loot your supplies.",
        ],
    }

    description = random.choice(descriptions.get(disaster_name, ["A chaotic disaster strikes the shelter!"]))
    slow_print(f"\nDay {game_state['day']} ends. {description}")
    disaster.apply(game_state)
    game_state["day"] += 1

    if (
        game_state["food"] <= 0
        or len(game_state["survivors"]) == 0
        or game_state["shelter_health"] <= 0
    ):
        slow_print("\nGame Over! You did not survive.")
        disable_combat_buttons()
        end_hunt_button.config(state=tk.DISABLED)
        end_day_button.config(state=tk.DISABLED)
        expand_button.config(state=tk.DISABLED)
        design_button.config(state=tk.DISABLED)
        repair_button.config(state=tk.DISABLED)
        scavenge_button.config(state=tk.DISABLED)
    else:
        slow_print(f"\nDay {game_state['day']} begins.")
        update_shelter_ui()

# =========================
# === HUNT / COMBAT     ===
# =========================

monster_list = [
    {"name": "Zombie", "health": 15, "attack": 3, "ability": "none"},
    {"name": "Bloated Zombie", "health": 22, "attack": 3, "ability": "on_death_explode"},
    {"name": "Fast Zombie", "health": 12, "attack": 6, "ability": "double_attack_chance"},
    {"name": "Junk Armour Zombie", "health": 35, "attack": 3, "ability": "reduced_damage"},
    {"name": "Exploding Pus Zombie", "health": 2, "attack": 4, "ability": "on_death_big_explode"},
    {"name": "Cannibal", "health": 14, "attack": 5, "ability": "lifesteal"},
    {"name": "Eradiated Camel", "health": 25, "attack": 3, "ability": "radiation_dot"},
    {"name": "Giant Spider", "health": 10, "attack": 4, "ability": "poison"},
    {"name": "Zombie that had once been a Jehova's witness", "health": 12, "attack": 5, "ability": "talk_stun"},
    {"name": "Kangaroo Zombie", "health": 10, "attack": 10, "ability": "high_crit"},
    {"name": "Other Survivors", "health": 18, "attack": 4, "ability": "steal_ammo"},
    {"name": "Wombat with Human Intellect", "health": 11, "attack": 2, "ability": "burrow_block"},
    {"name": "Shaolin Zombie", "health": 16, "attack": 5, "ability": "counter"},
    {"name": "Gorilla that had previously killed 100 men", "health": 110, "attack": 20, "ability": "enrage"},
]

def start_hunt():
    if game_state["in_hunt"] or game_state["in_scavenge"]:
        messagebox.showwarning("Warning", "Already on a mission!")
        return
    if not game_state["survivors"]:
        messagebox.showwarning("Warning", "No survivors left to hunt!")
        return

    game_state["in_hunt"] = True
    survivor = random.choice(game_state["survivors"])
    game_state["current_survivor"] = survivor

    if "role_instance" not in survivor:
        role_map = {
            "Combatant": Combatant,
            "Healer": Healer,
            "Builder": Builder,
            "Scout": Scout,
            "Guardian": Guardian,
        }
        role_cls = role_map.get(survivor["role"], Combatant)
        survivor["role_instance"] = role_cls()

    game_state["current_monster"] = random.choice(monster_list).copy()
    game_state["blocking"] = False

    slow_print("\nStarting a hunt mission...")
    slow_print(f"{survivor['name']} is hunting...")
    slow_print(f"\nA {game_state['current_monster']['name']} appears!")

    enable_combat_buttons()
    start_hunt_button.config(state=tk.DISABLED)
    scavenge_button.config(state=tk.DISABLED)
    end_hunt_button.config(state=tk.NORMAL)

    update_hunt_ui()
    update_combat_ui()

def end_hunt():
    if not game_state["in_hunt"]:
        messagebox.showwarning("Warning", "No active hunt!")
        return

    game_state["in_hunt"] = False
    game_state["current_survivor"] = None
    game_state["current_monster"] = None
    game_state["blocking"] = False

    disable_combat_buttons()
    start_hunt_button.config(state=tk.NORMAL)
    scavenge_button.config(state=tk.NORMAL)
    end_hunt_button.config(state=tk.DISABLED)

    slow_print("\nMission ended.")
    update_hunt_ui()
    update_combat_ui()

def apply_monster_ability_on_hit(monster, survivor, damage):
    ability = monster.get("ability", "none")
    # abilities that modify damage or add effects
    if ability == "lifesteal":
        heal = damage // 2
        monster["health"] += heal
        slow_print(f"The {monster['name']} feeds on flesh and heals {heal} HP.")
    elif ability == "radiation_dot":
        extra = random.randint(1, 3)
        survivor["health"] -= extra
        slow_print(f"Radiation burns {survivor['name']} for extra {extra} damage.")
    elif ability == "poison":
        extra = random.randint(2, 4)
        survivor["health"] -= extra
        slow_print(f"Poison seeps into {survivor['name']}'s veins for {extra} extra damage.")
    elif ability == "high_crit":
        if random.randint(1, 4) == 1:
            crit = damage
            survivor["health"] -= crit
            slow_print(f"The {monster['name']} lands a brutal kick for extra {crit} damage!")
    elif ability == "steal_ammo":
        stolen = min(game_state["ammo"], random.randint(1, 3))
        game_state["ammo"] -= stolen
        slow_print(f"The {monster['name']} steals {stolen} ammo from your supplies!")
    elif ability == "enrage":
        if monster["health"] < 40 and not monster.get("enraged", False):
            monster["enraged"] = True
            monster["attack"] += 5
            slow_print(f"The {monster['name']} becomes enraged! Its attacks grow stronger.")

def apply_monster_ability_on_death(monster, survivor):
    ability = monster.get("ability", "none")
    if ability == "on_death_explode":
        dmg = random.randint(3, 7)
        survivor["health"] -= dmg
        slow_print(f"The {monster['name']} bursts, splashing bile! {survivor['name']} takes {dmg} damage.")
    elif ability == "on_death_big_explode":
        dmg = random.randint(8, 15)
        survivor["health"] -= dmg
        slow_print(f"The {monster['name']} detonates violently! {survivor['name']} takes {dmg} massive damage.")

def maybe_monster_counter(monster, survivor, damage_dealt):
    ability = monster.get("ability", "none")
    if ability == "counter" and random.randint(1, 3) == 1:
        counter_dmg = random.randint(3, 7)
        survivor["health"] -= counter_dmg
        slow_print(f"The {monster['name']} counters the attack! {survivor['name']} takes {counter_dmg} damage.")

def player_turn(action):
    survivor = game_state["current_survivor"]
    monster = game_state["current_monster"]
    if survivor is None or monster is None:
        return

    role_inst = survivor.get("role_instance", None)

    if action == "attack":
        damage = role_inst.perform_attack() if role_inst else random.randint(3, 7)
        # Junk Armour reduces damage
        if monster.get("ability") == "reduced_damage":
            reduced = max(1, damage - 2)
            slow_print(f"The {monster['name']}'s junk armour absorbs some damage ({damage}->{reduced}).")
            damage = reduced
        monster["health"] -= damage
        slow_print(f"\n{survivor['name']} strikes the {monster['name']} for {damage} damage!")
        game_state["blocking"] = False
        maybe_monster_counter(monster, survivor, damage)

    elif action == "block":
        game_state["blocking"] = True
        slow_print(f"\n{survivor['name']} braces to block incoming attacks.")

    elif action == "use_medicine":
        if role_inst and hasattr(role_inst, "perform_heal"):
            heal_amount = role_inst.perform_heal(game_state)
            if heal_amount > 0 and survivor["health"] < survivor["max_health"]:
                survivor["health"] = min(survivor["max_health"], survivor["health"] + heal_amount)
                slow_print(f"\n{survivor['name']} uses medicine and heals {heal_amount} HP.")
                game_state["blocking"] = False
            else:
                slow_print("\nNo effective healing possible (no medicine or health full).")
                return
        else:
            slow_print("\nThis survivor cannot use medicine effectively.")
            return

    elif action == "run":
        if random.randint(1, 2) == 1:
            slow_print(f"\n{survivor['name']} escapes successfully!")
            end_hunt()
            return
        else:
            slow_print(f"\n{survivor['name']} fails to escape!")
            game_state["blocking"] = False

    if monster["health"] <= 0:
        slow_print(f"\nYou defeated the {monster['name']}!")
        apply_monster_ability_on_death(monster, survivor)
        if survivor["health"] <= 0:
            slow_print(f"{survivor['name']} dies from the monster's death throes.")
            if survivor in game_state["survivors"]:
                game_state["survivors"].remove(survivor)
            end_hunt()
            update_shelter_ui()
            return

        if survivor["role"] == "Combatant":
            ammo_found = random.randint(1, 3)
            game_state["ammo"] += ammo_found
            slow_print(f"Found {ammo_found} ammo!")
        elif survivor["role"] == "Healer":
            med_found = random.randint(1, 2)
            game_state["medicine"] += med_found
            slow_print(f"Found {med_found} medicine!")
        elif survivor["role"] == "Builder":
            scrap_found = random.randint(1, 3)
            game_state["scrap"] += scrap_found
            slow_print(f"Found {scrap_found} scrap metal!")
        elif survivor["role"] == "Scout":
            bonus_food = random.randint(1, 4)
            game_state["food"] += bonus_food
            slow_print(f"The Scout recovers {bonus_food} extra food from the corpse.")
        end_hunt()
        update_shelter_ui()
        return

    enemy_turn()

def enemy_turn():
    survivor = game_state["current_survivor"]
    monster = game_state["current_monster"]
    if survivor is None or monster is None:
        return

    # Fast zombie: chance to block instead of attack
    if random.randint(1, 6) == 6:
        monster["blocking"] = True
        slow_print(f"\nThe {monster['name']} raises its guard and prepares to block!")
    else:
        monster["blocking"] = False

    damage = monster["attack"]

    # Guardian blocks better
    if game_state["blocking"]:
        if survivor.get("role") == "Guardian":
            damage = max(1, damage // 3)
            slow_print(f"{survivor['name']} (Guardian) absorbs most of the attack!")
        else:
            damage = max(1, damage // 2)
            slow_print(f"{survivor['name']} blocks part of the attack!")

    survivor["health"] -= damage
    slow_print(f"\nThe {monster['name']} attacks! {survivor['name']} takes {damage} damage.")
    apply_monster_ability_on_hit(monster, survivor, damage)

    # Fast zombie: chance for extra attack
    if monster.get("ability") == "double_attack_chance" and random.randint(1, 4) == 1 and survivor["health"] > 0:
        extra = max(1, monster["attack"] // 2)
        survivor["health"] -= extra
        slow_print(f"The {monster['name']} lunges again for {extra} extra damage!")

    if survivor["health"] <= 0:
        slow_print(f"\n{survivor['name']} has died.")
        if survivor in game_state["survivors"]:
            game_state["survivors"].remove(survivor)
        end_hunt()
        update_shelter_ui()
        return

    update_hunt_ui()
    update_combat_ui()

