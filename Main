            "find_scrap": 10,
            "find_ammo": 5,
            "find_survivor": 10,
            "ambush": 10,
            "injury": 5,
            "mini_disaster": 3,
            "nothing": 2,
        },
    },
    {
        "name": "Industrial Yard",
        "desc": "Twisted metal and broken machinery—scrap heaven, danger included.",
        "weights": {
            "find_food": 5,
            "find_medicine": 5,
            "find_scrap": 35,
            "find_ammo": 10,
            "find_survivor": 5,
            "ambush": 15,
            "injury": 10,
            "mini_disaster": 5,
            "nothing": 2,
        },
    },
    {
        "name": "Military Checkpoint",
        "desc": "Abandoned barricades and rusted vehicles—ammo and gear, if you survive.",
        "weights": {
            "find_food": 10,
            "find_medicine": 10,
            "find_scrap": 15,
            "find_ammo": 25,
            "find_survivor": 5,
            "ambush": 20,
            "injury": 10,
            "mini_disaster": 5,
            "nothing": 2,
        },
    },
]

def start_scavenge():
    if game_state["in_hunt"] or game_state["in_scavenge"]:
        messagebox.showwarning("Warning", "Already on a mission!")
        return
    if not game_state["survivors"]:
        messagebox.showwarning("Warning", "No survivors available.")
        return

    survivor = random.choice(game_state["survivors"])
    game_state["current_survivor"] = survivor
    game_state["in_scavenge"] = True

    if "role_instance" not in survivor:
        role_map = {
            "Combatant": Combatant,
            "Healer": Healer,
            "Builder": Builder,
            "Scout": Scout,
            "Guardian": Guardian,
        }
        survivor["role_instance"] = role_map.get(survivor["role"], Combatant)()

    location = random.choice(SCAVENGE_LOCATIONS)
    game_state["current_scavenge_location"] = location
    slow_print(f"\n{survivor['name']} heads out to scavenge at the {location['name']}...")
    slow_print(location["desc"])

    scavenge_button.config(state=tk.DISABLED)
    start_hunt_button.config(state=tk.DISABLED)

    root.after(800, resolve_scavenge)

def resolve_scavenge():
    survivor = game_state["current_survivor"]
    game_state["in_scavenge"] = False
    location = game_state["current_scavenge_location"] or SCAVENGE_LOCATIONS[0]
    base_weights = location["weights"].copy()

    role_inst = survivor.get("role_instance", None)
    if role_inst:
        bonus = role_inst.scavenge_bonus(game_state)
        if "good_find_bonus" in bonus:
            for key in ["find_food", "find_medicine", "find_scrap", "find_ammo", "find_survivor"]:
                base_weights[key] = max(0, base_weights.get(key, 0) + bonus["good_find_bonus"])
        if "ambush_penalty" in bonus:
            base_weights["ambush"] = max(0, base_weights.get("ambush", 0) + bonus["ambush_penalty"])

    events = list(base_weights.items())
    total = sum(w for _, w in events)
    if total <= 0:
        events = [("nothing", 1)]
        total = 1

    r = random.randint(1, total)
    cumulative = 0
    outcome = "nothing"
    for event, weight in events:
        cumulative += weight
        if r <= cumulative:
            outcome = event
            break

    if outcome == "find_food":
        amount = random.randint(5, 15)
        game_state["food"] += amount
        slow_print(f"{survivor['name']} finds {amount} food.")

    elif outcome == "find_medicine":
        amount = random.randint(1, 4)
        game_state["medicine"] += amount
        slow_print(f"{survivor['name']} finds {amount} medicine.")

    elif outcome == "find_scrap":
        amount = random.randint(3, 8)
        game_state["scrap"] += amount
        slow_print(f"{survivor['name']} finds {amount} scrap.")

    elif outcome == "find_ammo":
        amount = random.randint(2, 6)
        game_state["ammo"] += amount
        slow_print(f"{survivor['name']} finds {amount} ammo.")

    elif outcome == "find_survivor":
        if len(game_state["survivors"]) >= max_survivors():
            slow_print(f"{survivor['name']} finds someone, but the shelter is full. They move on.")
        else:
            new_name = random.choice(["Alex", "Morgan", "Sam", "Riley", "Jordan", "Casey", "Harper", "Quinn"])
            new_survivor = {
                "name": new_name,
                "health": random.randint(60, 100),
                "max_health": 100,
                "role": random.choice(["Combatant", "Healer", "Builder", "Scout", "Guardian"]),
                "hunger": 0
            }
            game_state["survivors"].append(new_survivor)
            slow_print(f"{survivor['name']} finds a new survivor: {new_name} joins the shelter.")
            rebuild_survivor_buttons()

    elif outcome == "ambush":
        slow_print(f"{survivor['name']} is ambushed by zombies!")
        start_scavenge_combat()
        return

    elif outcome == "injury":
        dmg = random.randint(5, 20)
        survivor["health"] -= dmg
        slow_print(f"{survivor['name']} is injured while scavenging. Loses {dmg} HP.")
        if survivor["health"] <= 0:
            slow_print(f"{survivor['name']} dies from their wounds.")
            if survivor in game_state["survivors"]:
                game_state["survivors"].remove(survivor)
            rebuild_survivor_buttons()

    elif outcome == "mini_disaster":
        dmg = random.randint(5, 15)
        game_state["shelter_health"] = max(0, game_state["shelter_health"] - dmg)
        slow_print(f"A sudden hazard occurs! The shelter suffers {dmg} damage while {survivor['name']} is away.")

    elif outcome == "nothing":
        slow_print(f"{survivor['name']} finds nothing of value.")

    scavenge_button.config(state=tk.NORMAL)
    start_hunt_button.config(state=tk.NORMAL)
    update_shelter_ui()

def start_scavenge_combat():
    game_state["in_hunt"] = True
    survivor = game_state["current_survivor"]

    if "role_instance" not in survivor:
        role_map = {
            "Combatant": Combatant,
            "Healer": Healer,
            "Builder": Builder,
            "Scout": Scout,
            "Guardian": Guardian,
        }
        survivor["role_instance"] = role_map.get(survivor["role"], Combatant)()

    game_state["current_monster"] = random.choice(monster_list).copy()
    game_state["blocking"] = False

    slow_print(f"A {game_state['current_monster']['name']} attacks during scavenging!")

    enable_combat_buttons()
    start_hunt_button.config(state=tk.DISABLED)
    scavenge_button.config(state=tk.DISABLED)
    end_hunt_button.config(state=tk.NORMAL)

    update_hunt_ui()
    update_combat_ui()

# ============================
# === SHELTER BUILD / GRID ===
# ============================

grid_buttons = []

def rebuild_grid_ui():
    for widget in grid_frame.winfo_children():
        widget.destroy()
    grid_buttons.clear()

    size = game_state["grid_size"]
    for i in range(size):
        row = []
        for j in range(size):
            btn = tk.Button(
                grid_frame,
                text="",
                width=3,
                height=1,
                command=lambda x=i, y=j: on_grid_click(x, y),
                state=tk.DISABLED,
                bg="#4CAF50"
            )
            btn.grid(row=i, column=j, padx=2, pady=2)
            row.append(btn)
        grid_buttons.append(row)

    update_grid_ui()

def update_grid_ui():
    size = game_state["grid_size"]
    for i in range(size):
        for j in range(size):
            tile = game_state["shelter_grid"][i][j]
            health = game_state["grid_health"][i][j]
            if tile == 1:
                if health <= 0:
                    color = "#795548"
                elif health == 1:
                    color = "#FF9800"
                else:
                    color = "#333333"
            else:
                if health <= 0:
                    color = "#9E9E9E"
                else:
                    color = "#8BC34A"
            grid_buttons[i][j].config(bg=color)

def toggle_design_mode():
    game_state["design_mode"] = not game_state["design_mode"]
    game_state["repair_mode"] = False

    size = game_state["grid_size"]
    if game_state["design_mode"]:
        design_button.config(text="Finish Design", bg="#4CAF50")
        repair_button.config(state=tk.DISABLED)
        slow_print("\nDesign Mode: Click tiles to build/remove walls. Building a wall costs 1 scrap.")
        for i in range(size):
            for j in range(size):
                grid_buttons[i][j].config(state=tk.NORMAL)
    else:
        design_button.config(text="Design Shelter", bg="#FF9800")
        repair_button.config(state=tk.NORMAL)
        for i in range(size):
            for j in range(size):
                grid_buttons[i][j].config(state=tk.DISABLED)
    update_grid_ui()

def toggle_repair_mode():
    if game_state["current_survivor"] is None or game_state["current_survivor"].get("role") != "Builder":
        messagebox.showwarning("Warning", "Select a Builder to repair the shelter!")
        return

    game_state["repair_mode"] = not game_state["repair_mode"]
    game_state["design_mode"] = False

    size = game_state["grid_size"]
    if game_state["repair_mode"]:
        repair_button.config(text="Finish Repair", bg="#4CAF50")
        design_button.config(state=tk.DISABLED)
        slow_print("\nRepair Mode: Click damaged/destroyed tiles to repair. Repair costs 1 or 3 scrap.")
        for i in range(size):
            for j in range(size):
                grid_buttons[i][j].config(state=tk.NORMAL)
    else:
        repair_button.config(text="Repair Shelter", bg="#FF9800")
        design_button.config(state=tk.NORMAL)
        for i in range(size):
            for j in range(size):
                grid_buttons[i][j].config(state=tk.DISABLED)
    update_grid_ui()

def on_grid_click(x, y):
    if game_state["design_mode"]:
        tile = game_state["shelter_grid"][x][y]
        if tile == 0:
            if game_state["scrap"] >= 1:
                game_state["scrap"] -= 1
                game_state["shelter_grid"][x][y] = 1
                game_state["grid_health"][x][y] = 2
                slow_print(f"Built a wall at ({x},{y}). -1 scrap.")
            else:
                messagebox.showwarning("Warning", "Not enough scrap to build a wall!")
        else:
            game_state["shelter_grid"][x][y] = 0
            game_state["grid_health"][x][y] = 2
            slow_print(f"Removed a wall at ({x},{y}).")
        update_shelter_ui()

    elif game_state["repair_mode"]:
        tile = game_state["shelter_grid"][x][y]
        health = game_state["grid_health"][x][y]
        if health >= 2:
            slow_print(f"Tile at ({x},{y}) is already healthy.")
            return
        cost = 1 if health == 1 else 3
        if game_state["scrap"] < cost:
            messagebox.showwarning("Warning", f"Not enough scrap to repair (need {cost}).")
            return
        game_state["scrap"] -= cost
        game_state["grid_health"][x][y] = 2
        if tile == 0:
            game_state["shelter_grid"][x][y] = 1
        game_state["shelter_health"] = min(
            game_state["max_shelter_health"], game_state["shelter_health"] + 5
        )
        slow_print(f"Repaired tile at ({x},{y}). -{cost} scrap, +5 shelter health.")
        update_shelter_ui()

def expand_shelter():
    size = game_state["grid_size"]
    if size >= game_state["max_grid_size"]:
        messagebox.showinfo("Info", "Shelter is already at maximum size.")
        return
    if game_state["scrap"] < 10:
        messagebox.showwarning("Warning", "Need 10 scrap to expand the shelter!")
        return
    if not any(s["role"] == "Builder" for s in game_state["survivors"]):
        messagebox.showwarning("Warning", "You need a Builder to expand the shelter!")
        return

    game_state["scrap"] -= 10
    new_size = size + 1

    for row in game_state["shelter_grid"]:
        row.append(0)
    game_state["shelter_grid"].append([0 for _ in range(new_size)])

    for row in game_state["grid_health"]:
        row.append(2)
    game_state["grid_health"].append([2 for _ in range(new_size)])

    game_state["grid_size"] = new_size
    slow_print(f"Shelter expanded to {new_size}x{new_size}! -10 scrap.")
    rebuild_grid_ui()
    update_shelter_ui()

# =====================
# === UI UPDATES    ===
# =====================

def update_shelter_ui():
    day_label.config(text=f"Day: {game_state['day']}")
    food_label.config(text=f"Food: {game_state['food']}")
    medicine_label.config(text=f"Medicine: {game_state['medicine']}")
    ammo_label.config(text=f"Ammo: {game_state['ammo']}")
    scrap_label.config(text=f"Scrap: {game_state['scrap']}")
    shelter_hp_label.config(text=f"Shelter HP: {game_state['shelter_health']}/{game_state['max_shelter_health']}")
    grid_size_label.config(text=f"Shelter Size: {game_state['grid_size']}x{game_state['grid_size']}")
    cap_label.config(text=f"Survivor Cap: {len(game_state['survivors'])}/{max_survivors()}")

    survivors_text = "Survivors:\n"
    for survivor in game_state["survivors"]:
        health_status = f"Health: {survivor['health']}/{survivor['max_health']}"
        hunger_status = f"Hunger: {survivor['hunger']}"
        role_status = f"Role: {survivor['role']}"
        survivors_text += f"- {survivor['name']} ({health_status}, {hunger_status}, {role_status})\n"
    survivors_label.config(text=survivors_text)

    update_grid_ui()
    rebuild_survivor_buttons()

def update_hunt_ui():
    if game_state["in_hunt"] and game_state["current_survivor"]:
        s = game_state["current_survivor"]
        health_label.config(text=f"{s['name']}'s HP: {s['health']}/{s['max_health']}")
    else:
        health_label.config(text="")

def update_combat_ui():
    if game_state["in_hunt"] and game_state["current_monster"]:
        m = game_state["current_monster"]
        monster_label.config(text=f"Monster: {m['name']} (HP: {m['health']})")
    else:
        monster_label.config(text="")

def select_survivor(survivor):
    game_state["current_survivor"] = survivor
    slow_print(f"\nSelected {survivor['name']} for role assignment or actions.")
    update_shelter_ui()

def enable_combat_buttons():
    attack_button.config(state=tk.NORMAL)
    block_button.config(state=tk.NORMAL)
    potion_button.config(state=tk.NORMAL)
    run_button.config(state=tk.NORMAL)

def disable_combat_buttons():
    attack_button.config(state=tk.DISABLED)
    block_button.config(state=tk.DISABLED)
    potion_button.config(state=tk.DISABLED)
    run_button.config(state=tk.DISABLED)

def rebuild_survivor_buttons():
    for widget in role_select_frame.winfo_children():
        widget.destroy()
    for i, survivor in enumerate(game_state["survivors"]):
        tk.Button(
            role_select_frame,
            text=survivor["name"],
            command=lambda s=survivor: select_survivor(s),
            font=custom_font,
            bg="#4CAF50",
            fg="white"
        ).grid(row=0, column=i, padx=3, pady=3)

